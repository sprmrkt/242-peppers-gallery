{
  "format": "page",
  "id": "page",
  "label": "Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "config": {
          "label": "UID"
        },
        "type": "UID"
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "list": {
              "type": "SharedSlice"
            },
            "feature": {
              "type": "SharedSlice"
            },
            "content_list": {
              "type": "SharedSlice"
            },
            "large_media": {
              "type": "SharedSlice"
            },
            "image_grid": {
              "type": "SharedSlice"
            },
            "hero": {
              "type": "SharedSlice"
            },
            "text": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      },
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      }
    },
    "Preview Card Content": {
      "preview_image": {
        "type": "Image",
        "config": {
          "label": "Preview image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "placeholder": "",
          "allowTargetBlank": true,
          "single": "paragraph,strong,em"
        }
      },
      "preview_vimeo": {
        "type": "Embed",
        "config": {
          "label": "Preview Vimeo",
          "placeholder": ""
        }
      },
      "preview_video": {
        "type": "Link",
        "config": {
          "label": "Preview Video",
          "placeholder": "",
          "select": "media",
          "allowText": false
        }
      },
      "video_poster_image": {
        "type": "Image",
        "config": {
          "label": "video poster image",
          "constraint": {},
          "thumbnails": []
        }
      }
    }
  }
}
