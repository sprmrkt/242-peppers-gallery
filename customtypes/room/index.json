{
  "format": "page",
  "id": "room",
  "label": "Room",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "beds": {
        "type": "Text",
        "config": {
          "label": "Beds",
          "placeholder": ""
        }
      },
      "guests": {
        "type": "Text",
        "config": {
          "label": "Guests",
          "placeholder": ""
        }
      },
      "bath": {
        "type": "Text",
        "config": {
          "label": "Bath",
          "placeholder": ""
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "",
          "allowTargetBlank": false,
          "multi": "paragraph,strong,em,hyperlink"
        }
      },
      "features": {
        "type": "Group",
        "config": {
          "label": "Features",
          "repeat": true,
          "fields": {
            "feature": {
              "type": "Text",
              "config": {
                "label": "Feature",
                "placeholder": ""
              }
            }
          }
        }
      },
      "book_now_link": {
        "type": "Link",
        "config": {
          "label": "Book now link",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      },
      "type": {
        "type": "Select",
        "config": {
          "label": "Type",
          "placeholder": "",
          "options": ["Room", "Suite"],
          "default_value": "Room"
        }
      },
      "images": {
        "type": "Group",
        "config": {
          "label": "Images",
          "repeat": true,
          "fields": {
            "image": {
              "type": "Image",
              "config": {
                "label": "Image",
                "constraint": {},
                "thumbnails": []
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    },
    "Preview Card Content": {
      "preview_image": {
        "type": "Image",
        "config": {
          "label": "Preview image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "placeholder": "",
          "allowTargetBlank": false,
          "single": "paragraph,strong,em"
        }
      },
      "preview_vimeo": {
        "type": "Embed",
        "config": {
          "label": "Preview Vimeo",
          "placeholder": ""
        }
      },
      "preview_video": {
        "type": "Link",
        "config": {
          "label": "Preview Video",
          "placeholder": "",
          "select": "media",
          "allowText": false
        }
      },
      "video_poster_image": {
        "type": "Image",
        "config": {
          "label": "Video poster image",
          "constraint": {},
          "thumbnails": []
        }
      }
    }
  }
}
